# ── Database ───────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres service.
# Local dev: postgresql://localhost:5432/hextropian_crm
DATABASE_URL=postgresql://localhost:5432/hextropian_crm

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development   # Set to "production" on Railway

# ── JWT Secrets ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace_with_64_byte_random_base64_string
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_base64_string

# ── CORS ───────────────────────────────────────────────────────────────────────
# In production, set this to your Railway app URL (e.g. https://myapp.railway.app).
# Not required when the backend serves the frontend from the same origin.
FRONTEND_URL=http://localhost:5173

# ── App URL (used in password reset links) ─────────────────────────────────────
APP_URL=http://localhost:5173   # Set to your Railway app URL in production

# ── File Uploads ───────────────────────────────────────────────────────────────
# Railway filesystems are ephemeral by default — uploads are lost on redeploy.
# To persist uploads, attach a Railway Volume and set this to the mount path
# (e.g. /data/uploads). Leave blank to use the default local path.
UPLOAD_DIR=

# ── Google OAuth2 (Calendar + Gmail integration) ───────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Leave blank to disable Google integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Anthropic API (AI features) ────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
